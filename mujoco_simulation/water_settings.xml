<mujoco>
  <!-- Central water / fluid parameters. Edit this file first. -->
  <option timestep="0.001" integrator="RK4" density="998" viscosity="0.001" gravity="0 0 -9.81" />

  <default>
    <!-- SolidWorks mesh geoms handle both collision and MuJoCo ellipsoid fluid forces. -->
    <default class="eel_collision_fluid">
      <geom contype="2" conaffinity="1" group="0" rgba="1 0 0 1"
            fluidshape="ellipsoid" fluidcoef="0.24 0.0 0.5 0.5 0.5" />
    </default>
  </default>
</mujoco>
