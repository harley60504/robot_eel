<mujoco model="eel_urdf">
  <compiler angle="radian" meshdir="eel_urdf/meshes" />
  <include file="water_settings.xml" />
  <visual>
    <global fovy="45" offwidth="1920" offheight="1080" />
    <quality shadowsize="0" />
    <rgba fog="0 0.5 0.8 1" />
    <map fogstart="1" fogend="5" />
  </visual>
  <asset>
    <mesh name="base_link_mesh" file="base_link.STL" />
    <mesh name="servo1_mesh" file="servo1.STL" />
    <mesh name="servo2_mesh" file="servo2.STL" />
    <mesh name="servo3_mesh" file="servo3.STL" />
    <mesh name="servo4_mesh" file="servo4.STL" />
    <mesh name="servo5_mesh" file="servo5.STL" />
    <mesh name="servo6_mesh" file="servo6.STL" />
    <texture name="texplane" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .15 .2" type="2d" width="512" height="512" mark="cross" markrgb=".8 .8 .8" />
    <material name="matplane" reflectance="0.5" texture="texplane" texrepeat="4 4" texuniform="true" />
    <material name="water_visual_mat" rgba="0 0.4 0.9 0.2" reflectance="0" shininess="0" specular="0" />
    <material name="wall_brown_mat" rgba="0.25 0.18 0.10 1" reflectance="0.02" specular="0" shininess="0" />
    <material name="eel_mat" rgba="0.79216 0.81961 0.93333 1" reflectance="0.2" specular="0.35" shininess="0.4" />
    <material name="joint_marker_red" rgba="1 0 0 1" specular="0" shininess="0" reflectance="0" />
  </asset>
  <contact>
    <exclude body1="base_link" body2="servo1" />
    <exclude body1="servo1" body2="servo2" />
    <exclude body1="servo2" body2="servo3" />
    <exclude body1="servo3" body2="servo4" />
    <exclude body1="servo4" body2="servo5" />
    <exclude body1="servo5" body2="servo6" />
  </contact>
  <worldbody>
    <include file="environment_3x1_5.xml" />
    <include file="eel_body.xml" />
  </worldbody>
  <actuator>
    <position joint="servo1" kp="100" />
    <position joint="servo2" kp="100" />
    <position joint="servo3" kp="100" />
    <position joint="servo4" kp="100" />
    <position joint="servo5" kp="100" />
    <position joint="servo6" kp="100" />
  </actuator>
</mujoco>
